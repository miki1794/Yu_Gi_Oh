<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE properties SYSTEM "http://java.sun.com/dtd/properties.dtd">

<properties>



    <entry key="save_utente">
        INSERT INTO Utenti(username, email, password, DataDiNascita, NumeroDiTelefono, ruolo)
        VALUES (?, ?, ?, ?, ?, ?)
    </entry>

    <entry key="UPDATE_UTENTE">
        UPDATE Utenti
        SET username=?, email=?, password=?, DataDiNascita=?, NumeroDiTelefono=?, ruolo=?
        WHERE id=?
    </entry>

    <entry key="DELETE_UTENTE">
        DELETE FROM Utenti WHERE id=?
    </entry>

    <entry key="GET_USER_BY_ID">
        SELECT * FROM Utenti WHERE id=?
    </entry>

    <entry key="GET_USER_BY_EMAIL">
        SELECT * FROM Utenti WHERE email=?
    </entry>

    <entry key="GET_USER_BY_USERNAME">
        SELECT * FROM Utenti WHERE username=?
    </entry>

    <entry key="GET_ALL_USERS">
        SELECT * FROM Utenti
    </entry>


    <entry key="save_carta">
        INSERT INTO Carta(id, nome, prezzo, link)
        VALUES (?, ?, ?, ?)
    </entry>

    <entry key="UPDATE_CARTA">
        UPDATE Carta
        SET nome=?, prezzo=?, link=?
        WHERE id=?
    </entry>

    <entry key="DELETE_CARTA">
        DELETE FROM Carta WHERE id=?
    </entry>

    <entry key="GET_ALL_CARTE">
        SELECT * FROM Carta
    </entry>

    <entry key="GET_CARTE_BY_NAME">
        SELECT * FROM Carta WHERE nome=?
    </entry>

    <entry key="GET_CARTE_BY_ID">
        SELECT * FROM Carta WHERE id=?
    </entry>

    <entry key="SEARCH_PRODUCT">
        SELECT * FROM Carta WHERE nome LIKE ?
    </entry>




    <entry key="INSERT_ORDER">
        INSERT INTO Ordine(
        utente,
        stato,
        dataOrdine,
        prezzoTot,
        nome,
        cognome,
        via,
        civico,
        cap,
        paese
        )
        VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
    </entry>

    <entry key="UPDATE_ORDER">
        UPDATE Ordine
        SET
        utente=?,
        stato=?,
        dataOrdine=?,
        prezzoTot=?,
        nome=?,
        cognome=?,
        via=?,
        civico=?,
        cap=?,
        paese=?
        WHERE id=?
    </entry>

    <entry key="DELETE_ORDER">
        DELETE FROM Ordine WHERE id=?
    </entry>

    <entry key="GET_ORDER_BY_ID">
        SELECT * FROM Ordine WHERE id=?
    </entry>

    <entry key="GET_ALL_ORDERS">
        SELECT * FROM Ordine
    </entry>

    <entry key="GET_ORDERS_BY_USER">
        SELECT * FROM Ordine
        WHERE utente=?
        ORDER BY dataOrdine DESC
    </entry>

    <entry key="GET_ORDER_BY_STATO">
        SELECT * FROM Ordine
        WHERE stato=?
    </entry>

    <entry key="UPDATE_ORDER_STATUS">
        UPDATE Ordine
        SET stato=?
        WHERE id=?
    </entry>


    <entry key="INSERT_ORDERITEMS">
        INSERT INTO ItemOrdine(id, utente, nomeCarta, quantita, prezzo)
        VALUES (?, ?, ?, ?, ?)
    </entry>

    <entry key="UPDATE_ORDERITEMS">
        UPDATE ItemOrdine
        SET quantita=?, prezzo=?
        WHERE id=? AND utente=? AND nomeCarta=?
    </entry>

    <entry key="DELETE_ORDERITEMS">
        DELETE FROM ItemOrdine
        WHERE id=? AND utente=? AND nomeCarta=?
    </entry>

    <entry key="GET_ITEM_BY_ID">
        SELECT * FROM ItemOrdine WHERE id=?
    </entry>

</properties>