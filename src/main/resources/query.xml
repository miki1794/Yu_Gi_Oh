<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE properties SYSTEM "http://java.sun.com/dtd/properties.dtd">
<properties>
    <entry key="save_utente">
        INSERT INTO Utenti(username, email, password, DataDiNascita, NumeroDiTelefono, ruolo)
        VALUES (?, ?, ?, ?, ?, ?)
    </entry>
    <entry key="Update_utenti">
        UPDATE Utenti SET username=?, email=?, password=?, DataDiNascita=?, NumeroDiTelefono=?, ruolo=? WHERE id=?
    </entry>
    <entry key="Delete_utenti">
        DELETE FROM Utenti WHERE id=?
    </entry>
    <entry key="GET_USER_BY_ID">
        SELECT * FROM Utenti WHERE id=?
    </entry>
    <entry key="GET_USER_BY_EMAIL">
        SELECT * FROM Utenti WHERE email=?
    </entry>
    <entry key="GET_USER_BY_USERNAME">
        SELECT * FROM Utenti WHERE username=?
    </entry>
    <entry key="GET_ALL_USERS">
        SELECT * FROM Utenti
    </entry>
    <entry key="save_carta">
        INSERT INTO Carta( id,nome,prezzo,link)
        VALUES (?, ?, ?, ?)
    </entry>
    <entry key="Update_carta">
        UPDATE Carta SET nome=?,prezzo=?,img_path=? WHERE id=?
    </entry>
    <entry key="Delete_carta">
        DELETE FROM Carta WHERE id=?
    </entry>
    <entry key="GET_ALL_CARTE">
        SELECT * FROM Carta
    </entry>
    <entry key="GET_CARTE_BY_NAME">
        SELECT * FROM Carta WHERE nome=?
    </entry>
    <entry key="GET_CARTE_BY_ID">
        SELECT * FROM Carta WHERE id=?
    </entry>
    <entry key="SEARCH_PRODUCT">
        SELECT * FROM Carta WHERE nome LIKE ?
    </entry>
</properties>